# Host-specific deployment profile for garage host 10.7.1.200
SERVICE_NAME=archivist-eth2077
SERVICE_USER=wings
SERVICE_GROUP=wings

# Archivist source checkout in garage.
ARCHIVIST_SRC=/mnt/riffcastle/castle/garage/archivist-node
ARCHIVIST_LINK=/opt/archivist-eth2077

# Storage roots on 10.7.1.200.
DATA_DIR=/mnt/riffcastle/archivist/blockstores/archivist-eth2077
TMP_DIR=/mnt/riffcastle/archivist/tmp/eth2077

# Dedicated ETH2077 archivist network/API ports.
LISTEN_ADDR=/ip4/0.0.0.0/tcp/33170
DISC_PORT=33190
API_BINDADDR=0.0.0.0
API_PORT=33180

LOG_LEVEL=info
REPO_KIND=fs
FS_FSYNC_FILE=true
FS_FSYNC_DIR=true

NIMBLE_BIN=nimble

BUILD_ARCHIVIST=true
ENABLE_SERVICE=true
START_SERVICE=false

# Rollout helper behavior.
START_AFTER_SETUP=true
EDGE_IP=10.7.1.200
