# ETH2077 Archivist deployment defaults.
# Copy to archivist-eth2077.env and edit before running setup/preflight scripts.

SERVICE_NAME=archivist-eth2077
SERVICE_USER=wings
SERVICE_GROUP=wings

# Archivist source checkout in garage.
ARCHIVIST_SRC=/mnt/riffcastle/castle/garage/archivist-node
ARCHIVIST_LINK=/opt/archivist-eth2077

# MooseFS/NVMe goal-backed paths for ETH2077.
DATA_DIR=/mnt/mfs/eth2077/archivist
TMP_DIR=/mnt/mfs/eth2077/tmp

# Network ports (must stay distinct).
LISTEN_ADDR=/ip4/0.0.0.0/tcp/33070
DISC_PORT=33090
API_BINDADDR=0.0.0.0
API_PORT=33080

LOG_LEVEL=info
REPO_KIND=fs
FS_FSYNC_FILE=true
FS_FSYNC_DIR=true

# Tooling.
NIMBLE_BIN=nimble

# Setup behavior.
BUILD_ARCHIVIST=true
ENABLE_SERVICE=true
START_SERVICE=false

